# ═══════════════════════════════════════════════════════
# AcadLMS Backend — Environment Variables
# Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════

NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acadlms
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_64_HEX_CHARS_ACCESS_TOKEN_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS_REFRESH_TOKEN_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── DRM Encryption ──────────────────────────────────────
DRM_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_FOR_AES256_ENCRYPTION
DRM_TOKEN_SECRET=CHANGE_ME_DRM_TOKEN_SIGNING_SECRET

# ── Cloudflare R2 Storage ───────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_DRM=acadlms-drm
R2_BUCKET_PUBLIC=acadlms-public
R2_BUCKET_SCORM=acadlms-scorm

# ── AWS S3 (alternative to R2) ──────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Local Upload Directory ──────────────────────────────
SCORM_UPLOAD_DIR=./uploads

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── PayPal ──────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=AcadLMS

# ── SAML SSO ────────────────────────────────────────────
SAML_ISSUER=acadlms

# ── URLs ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── EasyPaisa (Telenor Microfinance) ───────────────────────────────────
EASYPAISA_MERCHANT_ID=your_merchant_id
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_URL=https://easypay.easypaisa.com.pk/easypay/

# ── JazzCash (Mobilink) ─────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_merchant_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_URL=https://payments.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/

# ── NayaPay ─────────────────────────────────────────────────────────────
NAYAPAY_API_KEY=your_api_key
NAYAPAY_API_SECRET=your_api_secret
NAYAPAY_URL=https://api.nayapay.com

# ── SadaPay ─────────────────────────────────────────────────────────────
SADAPAY_API_KEY=your_api_key
SADAPAY_API_SECRET=your_api_secret
SADAPAY_URL=https://api.sadapay.pk

# ── HBL Pay (Konnect) ───────────────────────────────────────────────────
HBLPAY_MERCHANT_ID=your_merchant_id
HBLPAY_SECRET_KEY=your_secret_key
HBLPAY_URL=https://konnect.hbl.com/pay

# ── UBL Omni ────────────────────────────────────────────────────────────
UBL_OMNI_ACCOUNT=your_omni_account_number

# ── 1Link IBFT ──────────────────────────────────────────────────────────
ONELINK_IBAN=PK36SCBL0000001123456702
ONELINK_TITLE=AcadLMS Payments

# ── Card (Visa/MC via Telr or 2Checkout) ────────────────────────────────
CARD_MERCHANT_ID=your_merchant_id
CARD_PAYMENT_URL=https://secure.telr.com/gateway/process.html
